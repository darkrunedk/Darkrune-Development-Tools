<Page x:Class="Darkrune_Development_Tools.Views.FileSearch"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Darkrune_Development_Tools.Views"
      xmlns:extensions="clr-namespace:Darkrune_Development_Tools.Extensions"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FileSearch">

    <Grid Style="{StaticResource GridPageStyle}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,0">
            <Button x:Name="SelectDirBtn" Content="Select Directory" Click="SelectDirBtn_Click" />
            <TextBlock x:Name="SelectedDirTxt" Text="No directory selected..." Margin="0,4,0,0" TextWrapping="Wrap" />
            <TextBox x:Name="SearchPatternTxtBox" Margin="0,4,0,0" Padding="2" extensions:PlaceholderService.PlaceholderText="File name (e.g. test.txt)" />
        </StackPanel>

        <ListView x:Name="SearchResultList" Grid.Row="0" Grid.Column="1" Margin="4,0,0,0" ItemsSource="{Binding SearchResults}" SelectionChanged="SearchResultList_SelectionChanged" />

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
            <Button x:Name="ExecuteActionBtn" Content="Search" VerticalAlignment="Center" Margin="4,0,0,0" Padding="4,2,4,2" IsEnabled="False" Click="ExecuteActionBtn_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <Button x:Name="OpenInExplorerBtn" Content="Open in file explorer" VerticalAlignment="Center" Margin="4,0,0,0" Padding="4,2,4,2" IsEnabled="False" Click="OpenInExplorerBtn_Click" />
        </StackPanel>

    </Grid>
</Page>
